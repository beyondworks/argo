{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "argo",
  "version": "0.1.0",
  "identifier": "com.beyondworks.argo",
  "build": {
    "frontendDist": "../public",
    "devUrl": "http://localhost:3001"
  },
  "app": {
    "windows": [
      {
        "title": "Argo",
        "width": 1280,
        "height": 820,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' http://localhost:3001 http://localhost:3999; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' http://localhost:3001 http://localhost:3999 https://*.supabase.co wss://*.supabase.co; frame-ancestors 'none'; object-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/node"],
    "resources": {
      "resources/server": "server"
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}