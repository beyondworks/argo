{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "argo",
  "version": "0.1.0",
  "identifier": "com.beyondworks.argo",
  "build": {
    "frontendDist": "../public",
    "devUrl": "http://localhost:3001"
  },
  "app": {
    "windows": [
      {
        "title": "Argo",
        "width": 1280,
        "height": 820,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}