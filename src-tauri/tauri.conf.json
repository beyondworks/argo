{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "argo",
  "version": "0.1.24",
  "identifier": "com.beyondworks.argo",
  "build": {
    "frontendDist": "../public",
    "devUrl": "http://localhost:3001"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Argo",
        "width": 1280,
        "height": 820,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 960,
        "minHeight": 640,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' http://localhost:3001 http://localhost:3011 http://localhost:3021 http://localhost:3999; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' http://localhost:3001 http://localhost:3011 http://localhost:3021 http://localhost:3999 https://*.supabase.co wss://*.supabase.co; frame-ancestors 'none'; object-src 'none'"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk4NUM3ODU4MkU2NTlEQzcKUldUSG5XVXVXSGhjbURBMTNYajlGUi9SbjF3TVk0VkFNQ3MrVEdUbnpBOWo4QkZkNnU4emVibWMK",
      "endpoints": [
        "https://github.com/beyondworks/argo-agent/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/node"
    ],
    "resources": {
      "resources/server": "server"
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsh"
      }
    }
  }
}