{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "remote": {
    "urls": [
      "http://localhost:3001",
      "http://localhost:3011",
      "http://localhost:3021",
      "http://localhost:3999"
    ]
  },
  "permissions": [
    "core:default",
    "updater:default",
    "process:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        {
          "url": "https://*"
        },
        {
          "url": "http://localhost:*"
        }
      ]
    },
    "core:window:allow-set-focus"
  ]
}
